letfun new_tests__rustc_coverage__let_else_loop__loopy(cond : bool) =
       let (=true) = cond in ()
       else (
         rust_primitives__hax__failure(
           "Explicit rejection by a phase in the Hax engine:
a node of kind [Loop] have been found in the AST

Note: the error was labeled with context `reject_not_in_ProVerif`.
",
           "{
 loop {
 Tuple0
 }
 }"
         ),
         ()
       ).

letfun new_tests__rustc_coverage__let_else_loop__e_loop_either_way(cond : bool) =
       let (=true) = cond in bitstring_err()
       else (
         rust_primitives__hax__failure(
           "Explicit rejection by a phase in the Hax engine:
a node of kind [Loop] have been found in the AST

Note: the error was labeled with context `reject_not_in_ProVerif`.
",
           "{
 loop {
 Tuple0
 }
 }"
         ),
         ()
       ).

letfun new_tests__rustc_coverage__let_else_loop__e_if(cond : bool) =
       if cond then (bitstring_err()) else (bitstring_err()).

letfun new_tests__rustc_coverage__let_else_loop__main(wildcard2 : bitstring) =
       let wildcard1: bitstring = (
         new_tests__rustc_coverage__let_else_loop__loopy(true)
       ) in
       ().

