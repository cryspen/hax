letfun new_tests__rustc_coverage__mcdc__if__say(message : bitstring) =
       let wildcard1: bitstring = (core_models__hint__black_box(message)) in
       ().

letfun new_tests__rustc_coverage__mcdc__if__mcdc_check_neither(
         a : bool, b : bool
       ) =
       if a && b
       then
         (let wildcard2: bitstring = (
            new_tests__rustc_coverage__mcdc__if__say("a and b")
          ) in
          ())
       else (
         let wildcard3: bitstring = (
           new_tests__rustc_coverage__mcdc__if__say("not both")
         ) in
         ()
       ).

