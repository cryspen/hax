letfun new_tests__rustc_coverage__mcdc__if__mcdc_check_tree_decision(
         a : bool, b : bool, c : bool
       ) =
       if a && b || c
       then
         (let wildcard10: bitstring = (
            new_tests__rustc_coverage__mcdc__if__say("pass")
          ) in
          ())
       else (
         let wildcard11: bitstring = (
           new_tests__rustc_coverage__mcdc__if__say("reject")
         ) in
         ()
       ).

letfun new_tests__rustc_coverage__mcdc__if__mcdc_check_not_tree_decision(
         a : bool, b : bool, c : bool
       ) =
       if a || b && c
       then
         (let wildcard12: bitstring = (
            new_tests__rustc_coverage__mcdc__if__say("pass")
          ) in
          ())
       else (
         let wildcard13: bitstring = (
           new_tests__rustc_coverage__mcdc__if__say("reject")
         ) in
         ()
       ).

letfun new_tests__rustc_coverage__mcdc__if__mcdc_nested_if(
         a : bool, b : bool, c : bool
       ) =
       if a || b
       then
         (let wildcard15: bitstring = (
            new_tests__rustc_coverage__mcdc__if__say("a or b")
          ) in
          if b && c
          then
            (let wildcard14: bitstring = (
               new_tests__rustc_coverage__mcdc__if__say("b and c")
             ) in
             ())
          else (()))
       else (
         let wildcard16: bitstring = (
           new_tests__rustc_coverage__mcdc__if__say("neither a nor b")
         ) in
         ()
       ).

