const new_tests__rustc_coverage__unreachable__v_UNREACHABLE_CLOSURE: bitstring.

letfun new_tests__rustc_coverage__unreachable__unreachable_function(
         wildcard1 : bitstring
       ) =
       rust_primitives__hax__failure(
         "Explicit rejection by a phase in the Hax engine:
a node of kind [Unsafe] have been found in the AST

Note: the error was labeled with context `reject_Unsafe`.
",
         "unsafe {
 rust_primitives::hax::never_to_any(
 core_models::hint::unreachable_unchecked(Tuple0),
 )
 }"
       ).

letfun new_tests__rustc_coverage__unreachable__unreachable_intrinsic(
         wildcard2 : bitstring
       ) =
       rust_primitives__hax__failure(
         "Explicit rejection by a phase in the Hax engine:
a node of kind [Unsafe] have been found in the AST

Note: the error was labeled with context `reject_Unsafe`.
",
         "unsafe {
 rust_primitives::hax::never_to_any(core_models::intrinsics::unreachable(Tuple0))
 }"
       ).

letfun new_tests__rustc_coverage__unreachable__main(wildcard8 : bitstring) =
       let wildcard7: bitstring = (
         if core_models__hint__black_box(false)
         then
           (let wildcard6: bitstring = (
              new_tests__rustc_coverage__unreachable__v_UNREACHABLE_CLOSURE(())
            ) in
            ())
         else (())
       ) in
       let wildcard5: bitstring = (
         if core_models__hint__black_box(false)
         then
           (let wildcard4: bitstring = (
              new_tests__rustc_coverage__unreachable__unreachable_function(())
            ) in
            ())
         else (())
       ) in
       if core_models__hint__black_box(false)
       then
         (let wildcard3: bitstring = (
            new_tests__rustc_coverage__unreachable__unreachable_intrinsic(())
          ) in
          ())
       else (()).

