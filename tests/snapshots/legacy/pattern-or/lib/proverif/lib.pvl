letfun new_tests__legacy__pattern_or__lib__t_E_cast_to_repr(
         x : new_tests__legacy__pattern_or__lib__t_E
       ) =
       let new_tests__legacy__pattern_or__lib__E_A() = x in 0
       else let new_tests__legacy__pattern_or__lib__E_B() = x in 1.

letfun new_tests__legacy__pattern_or__lib__bar(
         x : new_tests__legacy__pattern_or__lib__t_E
       ) =
       let new_tests__legacy__pattern_or__lib__E_A()|
       new_tests__legacy__pattern_or__lib__E_B() = x in ().

letfun new_tests__legacy__pattern_or__lib__nested(x : Option) =
       let Some(nat_to_bitstring(=1| =2)) = x in 1
       else let Some(nat_to_bitstring(x)) = x in x
       else let None() = x in 0.

letfun new_tests__legacy__pattern_or__lib__deep(x : bitstring) =
       let (=1| =2, Some(nat_to_bitstring(=3| =4))) = x in 0
       else let (x: nat, wildcard1: bitstring) = x in x.

letfun new_tests__legacy__pattern_or__lib__equivalent(x : bitstring) =
       let (=1, Some(nat_to_bitstring(=3)))|
       (=1, Some(nat_to_bitstring(=4)))|
       (=2, Some(nat_to_bitstring(=3)))|
       (=2, Some(nat_to_bitstring(=4))) = x in 0
       else let (x: nat, wildcard2: bitstring) = x in x.

letfun new_tests__legacy__pattern_or__lib__deep_capture(x : bitstring) =
       let (=1| =2, x: nat)| core_models__result__Result_Err((=3| =4, x: nat)) = x in x
       else let (x: nat, wildcard3: bitstring)|
       core_models__result__Result_Err((x: nat, wildcard4: bitstring)) = x in x.

