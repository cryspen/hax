channel c.

fun construct_fail() : bitstring
reduc construct_fail() = fail.

const empty: bitstring.
letfun bitstring_default() = empty.
letfun bitstring_err() = let x = construct_fail() in bitstring_default().

fun Some(bitstring): bitstring [data].
fun None(): bitstring [data].
letfun Option_err() = let x = construct_fail() in None().

fun True(): bitstring [data].
fun False(): bitstring [data].
letfun bool_default() = False().
letfun bool_err() = let x = construct_fail() in False().

fun nat_lit(nat): bitstring.

fun logical_and(bitstring, bitstring): bitstring.
fun logical_or(bitstring, bitstring): bitstring.

fun basic_structs__Ainitial__Ainitial(bitstring): bitstring [data].
reduc forall basic_structs__Ainitial__Ainitial__x: bitstring;
  accessor_basic_structs__Ainitial__basic_structs__Ainitial__Ainitial__x(basic_structs__Ainitial__Ainitial(basic_structs__Ainitial__Ainitial__x)) = basic_structs__Ainitial__Ainitial__x.
fun basic_structs__A__A(bitstring,
bitstring): bitstring [data].
reduc forall basic_structs__A__A__one: bitstring,
basic_structs__A__A__two: bitstring;
  accessor_basic_structs__A__basic_structs__A__A__one(basic_structs__A__A(basic_structs__A__A__one,
  basic_structs__A__A__two)) = basic_structs__A__A__one.
reduc forall basic_structs__A__A__one: bitstring,
basic_structs__A__A__two: bitstring;
  accessor_basic_structs__A__basic_structs__A__A__two(basic_structs__A__A(basic_structs__A__A__one,
  basic_structs__A__A__two)) = basic_structs__A__A__two.
fun basic_structs__B__B(bitstring): bitstring [data].
reduc forall basic_structs__B__B__0: bitstring;
  accessor_basic_structs__B__basic_structs__B__B__0(basic_structs__B__B(basic_structs__B__B__0)) = basic_structs__B__B__0.