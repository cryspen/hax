(* Run with:                                                       *)
(*   proverif -lib primitives.pvl lib.pvl                          *)
(* The `primitives.pvl` library ships with hax under                *)
(* `hax-lib/proof-libs/proverif/` and declares the standard         *)
(* `rust_primitives::*`, `core::*` and `hax_lib::*` symbols every    *)
(* extraction uses.                                                  *)
(*****************************************)
(* Preamble                              *)
(*****************************************)

channel c.

fun construct_fail() : bitstring
reduc construct_fail() = fail.

const empty: bitstring.
letfun bitstring_default() = empty.
letfun bitstring_err() = let x = construct_fail() in bitstring_default().

fun Some(bitstring): bitstring [data].
fun None(): bitstring [data].
letfun Option_err() = let x = construct_fail() in None().

fun True(): bitstring [data].
fun False(): bitstring [data].
letfun bool_default() = False().
letfun bool_err() = let x = construct_fail() in False().

fun nat_lit(nat): bitstring.

fun logical_and(bitstring, bitstring): bitstring.
fun logical_or(bitstring, bitstring): bitstring.


fun fn_to_letfun__A__A(bitstring,
bitstring): bitstring [data].
reduc forall fn_to_letfun__A__A__x: bitstring,
fn_to_letfun__A__A__y: bitstring;
  accessor_fn_to_letfun__A__fn_to_letfun__A__A__x(fn_to_letfun__A__A(fn_to_letfun__A__A__x,
  fn_to_letfun__A__A__y)) = fn_to_letfun__A__A__x.
reduc forall fn_to_letfun__A__A__x: bitstring,
fn_to_letfun__A__A__y: bitstring;
  accessor_fn_to_letfun__A__fn_to_letfun__A__A__y(fn_to_letfun__A__A(fn_to_letfun__A__A__x,
  fn_to_letfun__A__A__y)) = fn_to_letfun__A__A__y.
fun fn_to_letfun__B__B(bitstring): bitstring [data].
reduc forall fn_to_letfun__B__B__b: bitstring;
  accessor_fn_to_letfun__B__fn_to_letfun__B__B__b(fn_to_letfun__B__B(fn_to_letfun__B__B__b)) = fn_to_letfun__B__B__b.
letfun fn_to_letfun__some_function(wildcard: bitstring) =
True().
letfun fn_to_letfun__some_other_function(b: bitstring) =
nat_lit(5).
letfun fn_to_letfun__longer_function(x: bitstring) =
let b = (fn_to_letfun__some_function(rust_primitives__hax__Tuple0__Tuple0)) in
  let d = (fn_to_letfun__some_other_function(b)) in
  fn_to_letfun__A__A(nat_lit(12),
  nat_lit(9)).
letfun fn_to_letfun__another_longer_function(wildcard: bitstring) =
let b = (fn_to_letfun__some_function(rust_primitives__hax__Tuple0__Tuple0)) in
  let d = (fn_to_letfun__some_other_function(b)) in
  fn_to_letfun__B__B(False()).
letfun fn_to_letfun__void_function(wildcard: bitstring) =
let b = (fn_to_letfun__some_function(rust_primitives__hax__Tuple0__Tuple0)) in
  let d = (fn_to_letfun__some_other_function(b)) in
  rust_primitives__hax__Tuple0__Tuple0.