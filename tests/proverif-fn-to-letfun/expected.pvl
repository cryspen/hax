(*
  Run with:
    proverif -lib <hax>/hax-lib/proof-libs/proverif/primitives.pvl lib.pvl

  The `primitives.pvl` library ships with hax and supplies
  everything the extracted file references that isn't defined
  below: the public channel `c`, the `construct_fail` sink,
  `bitstring_default`/`bitstring_err`, the `Some`/`None`/
  `True`/`False`/`nat_lit` constructors, `logical_and`/`or`, and
  every `rust_primitives::*` / `core::*` / `hax_lib::*` opaque
  function the extraction surface needs.
*)


fun fn_to_letfun__A__A(bitstring,
bitstring): bitstring [data].
reduc forall fn_to_letfun__A__A__x_v: bitstring,
fn_to_letfun__A__A__y_v: bitstring;
  fn_to_letfun__A__A__x(fn_to_letfun__A__A(fn_to_letfun__A__A__x_v,
  fn_to_letfun__A__A__y_v)) = fn_to_letfun__A__A__x_v.
reduc forall fn_to_letfun__A__A__x_v: bitstring,
fn_to_letfun__A__A__y_v: bitstring;
  fn_to_letfun__A__A__y(fn_to_letfun__A__A(fn_to_letfun__A__A__x_v,
  fn_to_letfun__A__A__y_v)) = fn_to_letfun__A__A__y_v.
fun fn_to_letfun__B__B(bitstring): bitstring [data].
reduc forall fn_to_letfun__B__B__b_v: bitstring;
  fn_to_letfun__B__B__b(fn_to_letfun__B__B(fn_to_letfun__B__B__b_v)) = fn_to_letfun__B__B__b_v.
letfun fn_to_letfun__some_function(wildcard: bitstring) =
True().
letfun fn_to_letfun__some_other_function(b: bitstring) =
nat_lit(5).
letfun fn_to_letfun__longer_function(x: bitstring) =
let b = (fn_to_letfun__some_function(rust_primitives__hax__Tuple0__Tuple0)) in
  let d = (fn_to_letfun__some_other_function(b)) in
  fn_to_letfun__A__A(nat_lit(12),
  nat_lit(9)).
letfun fn_to_letfun__another_longer_function(wildcard: bitstring) =
let b = (fn_to_letfun__some_function(rust_primitives__hax__Tuple0__Tuple0)) in
  let d = (fn_to_letfun__some_other_function(b)) in
  fn_to_letfun__B__B(False()).
letfun fn_to_letfun__void_function(wildcard: bitstring) =
let b = (fn_to_letfun__some_function(rust_primitives__hax__Tuple0__Tuple0)) in
  let d = (fn_to_letfun__some_other_function(b)) in
  rust_primitives__hax__Tuple0__Tuple0.