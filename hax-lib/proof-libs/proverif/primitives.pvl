(*** level. Real protocol semantics don't care which heap-          ***)
(*** allocation flavour the bytes are in.                           ***)
letfun alloc__slice__Impl__to_vec(x: bitstring) = x.
letfun alloc__vec__Impl_1__as_slice(x: bitstring) = x.
letfun alloc__borrow__ToOwned__to_owned(x: bitstring) = x.
letfun alloc__boxed__Impl__new_kw(x: bitstring) = x.

