(*** rust_primitives::slice / sequence — slice / array primitives  ***)
(* Operations that actually compute something useful (`slice_index`,    *)
(* `array_slice`, `slice_to_array`) stay opaque `[data]` so distinct    *)
(* inputs stay distinguishable. The "convert one collection wrapper    *)
(* to another" helpers are identity letfuns: under the uniform-        *)
(* bitstring scheme there's only one ProVerif universe, so wrapping    *)
(* doesn't change the value. Without this, a value built via            *)
(* `&v[..]` symbolically differs from `v.as_slice()` and downstream    *)
(* equality checks fail vacuously.                                     *)

fun rust_primitives__slice__array_slice(bitstring, bitstring, bitstring): bitstring [data].
fun rust_primitives__slice__array_from_fn(bitstring): bitstring [data].
fun rust_primitives__slice__slice_index(bitstring, bitstring): bitstring [data].
fun rust_primitives__slice__slice_index_range(bitstring, bitstring, bitstring): bitstring [data].
letfun rust_primitives__slice__slice_to_array(x: bitstring) = x.
letfun rust_primitives__slice__as_slice(x: bitstring) = x.
fun rust_primitives__slice__len(bitstring): bitstring [data].

letfun rust_primitives__sequence__seq_to_vec(x: bitstring) = x.
letfun rust_primitives__sequence__vec_to_seq(x: bitstring) = x.
fun rust_primitives__sequence__seq_len(bitstring): bitstring [data].
fun rust_primitives__sequence__seq_index(bitstring, bitstring): bitstring [data].

letfun rust_primitives__unsize(x: bitstring) = x.

